PORT=3000

# Local development (MySQL)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_NAME=tu_base_de_datos

# SSL para Postgres (Neon suele requerir TLS)
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# synchronize solo desarrollo; en producción usar false + migraciones
DB_SYNCHRONIZE=false

# Ejecutar migraciones al arrancar (Postgres). Recomendado false y correr en release step.
DB_MIGRATIONS_RUN=false

DB_LOGGING=false
DB_TIMEZONE=Z

JWT_SECRET=cambia_esto_minimo_32_caracteres_seguro
# Duración del JWT en segundos (43200 = 12 h)
JWT_EXPIRES_SEC=43200

# Orígenes del frontend (coma separada). Vacío = sin CORS en prod vía código
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Tras migraciones existe usuario admin / Admin123! — cambiar contraseña al iniciar.
